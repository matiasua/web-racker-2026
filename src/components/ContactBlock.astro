---
import { company, formRecipients, systems } from '../data';
---
<section class="section" id="cotizar">
  <div class="container contact-grid">
    <div class="contact-quote__info">
      <span class="eyebrow">Cotización</span>
      <h2>Conversemos sobre tu proyecto</h2>
      <p class="lead">Podemos ayudarte a definir la solución adecuada según operación, altura útil, rotación y capacidad requerida.</p>
      <div class="contact-quote__chips" aria-hidden="true">
        <span>Respuesta en horas</span>
        <span>Asesoría técnica</span>
        <span>Solución a medida</span>
      </div>
      <ul class="contact-list">
        <li><strong>Dirección:</strong> {company.address}</li>
        <li><strong>Email:</strong> <a href={`mailto:${company.email}`}>{company.email}</a></li>
        <li><strong>Teléfono:</strong> <a href={`tel:${company.phone}`}>{company.phone}</a></li>
      </ul>
    </div>

    <div class="contact-quote__form-shell">
      <header class="contact-quote__form-header">
        <p class="contact-quote__form-kicker">Cotización Racker</p>
        <h3>Recibe una cotización en horas</h3>
      </header>

      <form
        class="contact-form quote-form contact-quote-form"
        action={`https://formsubmit.co/${formRecipients.primary}`}
        data-ajax-action={`https://formsubmit.co/ajax/${formRecipients.primary}`}
        data-contact-email={`${formRecipients.primary} / ${formRecipients.cc}`}
        method="POST"
      >
      <input type="hidden" name="_subject" value="Nueva solicitud de cotización - Racker" />
      <input type="hidden" name="_captcha" value="false" />
      <input type="hidden" name="_template" value="table" />
      <input type="hidden" name="_cc" value={formRecipients.cc} />
      <input type="hidden" name="origen" value="" data-contact-origin />
      <input type="hidden" name="email" value="" data-contact-email-copy />

      <div class="quote-form__feedback" role="status" aria-live="polite" hidden data-contact-feedback>
        <span class="quote-form__feedback-icon" aria-hidden="true">✓</span>
        <div>
          <strong data-contact-feedback-title>Solicitud enviada</strong>
          <p data-contact-feedback-text>Te responderemos en horas.</p>
        </div>
      </div>

      <fieldset class="quote-form__fieldset">
        <legend>Sistema de interés</legend>
        <div class="quote-form__products">
          {systems.map((system, index) => (
            <label class="quote-product">
              <input type="radio" name="producto" value={system.name} required={index === 0} />
              <span class="quote-product__content">
                <span class="quote-product__check" aria-hidden="true"></span>
                <span class="quote-product__name">{system.name}</span>
              </span>
            </label>
          ))}
          <label class="quote-product">
            <input type="radio" name="producto" value="Otro" />
            <span class="quote-product__content">
              <span class="quote-product__check" aria-hidden="true"></span>
              <span class="quote-product__name">Otro</span>
            </span>
          </label>
        </div>
      </fieldset>

      <div class="quote-form__grid">
        <input type="text" name="nombre" placeholder="Nombre" required />
        <input type="email" name="_replyto" placeholder="Correo electrónico" required />
      </div>

      <div class="quote-form__grid">
        <input type="tel" name="telefono" placeholder="Teléfono" required />
        <input type="text" name="empresa" placeholder="Empresa (opcional)" />
      </div>

      <input type="text" name="asunto" placeholder="Asunto" required />
      <textarea name="mensaje" rows="5" placeholder="Cuéntanos qué necesitas (metros, pallets, altura, operación, etc.)" required></textarea>
      <button type="submit" class="btn btn--primary">Enviar solicitud</button>
      </form>
    </div>
  </div>
</section>

<style>
  .contact-grid {
    align-items: start;
    gap: clamp(1rem, 2vw, 1.8rem);
  }

  .contact-quote__info {
    min-width: 0;
    overflow: hidden;
    border: 1px solid rgba(10, 23, 48, 0.08);
    border-radius: 24px;
    padding: clamp(1rem, 2.2vw, 1.6rem);
    background:
      linear-gradient(180deg, rgba(236, 243, 251, 0.95) 0%, rgba(245, 248, 253, 0.9) 100%),
      radial-gradient(circle at 95% 5%, rgba(255, 138, 29, 0.12), transparent 44%);
    box-shadow: 0 16px 32px rgba(10, 23, 48, 0.07);
  }

  .contact-quote__info .eyebrow {
    margin-bottom: 0.62rem;
  }

  .contact-quote__info h2 {
    margin-bottom: 0.7rem;
    font-size: clamp(2rem, 4vw, 3.25rem);
    line-height: 1.02;
    letter-spacing: -0.03em;
  }

  .contact-quote__info .lead {
    margin: 0;
  }

  .contact-quote__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 1rem 0 1.15rem;
  }

  .contact-quote__chips span {
    border-radius: 999px;
    border: 1px solid rgba(15, 76, 151, 0.2);
    background: rgba(255, 255, 255, 0.88);
    color: #1a4f97;
    font-weight: 700;
    letter-spacing: 0.01em;
    font-size: 0.79rem;
    padding: 0.38rem 0.68rem;
  }

  .contact-quote__form-shell {
    min-width: 0;
    overflow: hidden;
    border: 1px solid rgba(10, 23, 48, 0.12);
    border-radius: 24px;
    padding: clamp(0.85rem, 2vw, 1.25rem);
    background:
      linear-gradient(180deg, #ffffff 0%, #f6f9fe 100%),
      radial-gradient(circle at 100% 0%, rgba(15, 76, 151, 0.08), transparent 34%);
    box-shadow: 0 18px 34px rgba(10, 23, 48, 0.1);
  }

  .contact-quote__form-header {
    margin-bottom: 0.7rem;
    padding: 0 0.25rem;
  }

  .contact-quote__form-kicker {
    margin: 0 0 0.22rem;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.76rem;
    font-weight: 800;
  }

  .contact-quote__form-header h3 {
    margin: 0;
    color: #14488f;
    letter-spacing: -0.01em;
    font-size: clamp(1.2rem, 2.2vw, 1.65rem);
    line-height: 1.08;
  }

  .contact-quote-form {
    min-width: 0;
    overflow: hidden;
    gap: 0.72rem;
    border: 1px solid rgba(10, 23, 48, 0.09);
    border-radius: 20px;
    padding: 0.9rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(246, 249, 254, 0.98) 100%),
      radial-gradient(circle at 98% 2%, rgba(15, 76, 151, 0.06), transparent 35%);
  }

  .contact-quote-form .quote-form__feedback[hidden] {
    display: none !important;
  }

  .contact-quote-form .quote-form__fieldset {
    margin-bottom: 0;
  }

  .contact-quote-form .quote-form__products {
    gap: 0.6rem;
  }

  .contact-quote-form .quote-form__grid {
    gap: 0.62rem;
  }

  .contact-quote-form .quote-form__grid > * {
    min-width: 0;
  }

  .contact-quote-form .quote-product__name {
    font-size: clamp(0.92rem, 1.4vw, 1.05rem);
  }

  .contact-quote-form .quote-product__content {
    min-height: 48px;
    border-radius: 14px;
    background: #f7faff;
  }

  .contact-quote-form input:not([type='hidden']):not([type='radio']),
  .contact-quote-form textarea {
    border-radius: 14px;
    border-color: rgba(13, 27, 42, 0.17);
    background: #fff;
  }

  .contact-quote-form .btn {
    min-height: 52px;
  }

  .contact-quote-form textarea {
    min-height: 145px;
  }

  @media (max-width: 1024px) {
    .contact-quote__info,
    .contact-quote__form-shell {
      border-radius: 20px;
      padding: 1rem;
    }

    .contact-quote-form {
      padding: 0.85rem;
      border-radius: 18px;
    }
  }

  @media (max-width: 760px) {
    .contact-quote__info h2 {
      font-size: clamp(1.8rem, 9vw, 2.3rem);
      line-height: 1.05;
    }

    .contact-quote__chips {
      gap: 0.42rem;
      margin: 0.8rem 0 0.95rem;
    }

    .contact-quote__chips span {
      font-size: 0.73rem;
      padding: 0.32rem 0.58rem;
    }

    .contact-quote__form-header {
      margin-bottom: 0.6rem;
    }

    .contact-quote-form {
      padding: 0.78rem;
      gap: 0.58rem;
      border-radius: 16px;
    }

    .contact-quote-form textarea {
      min-height: 125px;
    }
  }
</style>

<script>
  (() => {
    const form = document.querySelector('.contact-quote-form');
    if (!(form instanceof HTMLFormElement)) return;

    const feedback = form.querySelector('[data-contact-feedback]');
    const feedbackIcon = form.querySelector('.quote-form__feedback-icon');
    const feedbackTitle = form.querySelector('[data-contact-feedback-title]');
    const feedbackText = form.querySelector('[data-contact-feedback-text]');
    const submitButton = form.querySelector('button[type="submit"]');
    const emailInput = form.querySelector('input[name="_replyto"]');
    const emailCopyInput = form.querySelector('[data-contact-email-copy]');
    const originInput = form.querySelector('[data-contact-origin]');
    const defaultSubmitLabel =
      submitButton instanceof HTMLButtonElement
        ? submitButton.textContent || 'Enviar solicitud'
        : 'Enviar solicitud';

    const clearFeedback = () => {
      if (!(feedback instanceof HTMLElement)) return;
      feedback.hidden = true;
      feedback.classList.remove('is-success', 'is-error');
    };

    const setFeedback = (type, title, text) => {
      if (!(feedback instanceof HTMLElement)) return;
      feedback.hidden = false;
      feedback.classList.remove('is-success', 'is-error');
      feedback.classList.add(type === 'success' ? 'is-success' : 'is-error');

      if (feedbackIcon instanceof HTMLElement) {
        feedbackIcon.textContent = type === 'success' ? '✓' : '!';
      }
      if (feedbackTitle instanceof HTMLElement) feedbackTitle.textContent = title;
      if (feedbackText instanceof HTMLElement) feedbackText.textContent = text;
    };

    clearFeedback();

    if (originInput instanceof HTMLInputElement) {
      originInput.value = window.location.href;
    }

    if (
      emailInput instanceof HTMLInputElement &&
      emailCopyInput instanceof HTMLInputElement
    ) {
      emailInput.addEventListener('input', () => {
        emailCopyInput.value = emailInput.value;
      });
    }

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      clearFeedback();

      if (!form.reportValidity()) return;

      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = true;
        submitButton.textContent = 'Enviando...';
      }

      try {
        const formData = new FormData(form);
        const replyEmail = formData.get('_replyto');
        if (typeof replyEmail === 'string') {
          formData.set('email', replyEmail);
        }

        const endpoint = form.dataset.ajaxAction || form.action;
        const response = await fetch(endpoint, {
          method: 'POST',
          headers: { Accept: 'application/json' },
          body: formData,
        });

        if (!response.ok) throw new Error('request_failed');

        form.reset();
        if (originInput instanceof HTMLInputElement) {
          originInput.value = window.location.href;
        }
        setFeedback(
          'success',
          'Solicitud enviada correctamente',
          'Gracias por contactarnos. Te responderemos en horas.'
        );
      } catch {
        setFeedback(
          'error',
          'No pudimos enviar tu solicitud',
          `Intenta nuevamente o escríbenos a ${form.dataset.contactEmail || 'd.fica@racker.cl / r.fica@racker.cl'}.`
        );
      } finally {
        if (submitButton instanceof HTMLButtonElement) {
          submitButton.disabled = false;
          submitButton.textContent = defaultSubmitLabel;
        }
      }
    });
  })();
</script>
