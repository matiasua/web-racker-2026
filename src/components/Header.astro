---
import { company, formRecipients } from "../data";
const pathname = Astro.url.pathname;

const links = [
  { href: "/", label: "Inicio" },
  { href: "/nosotros", label: "Nosotros" },
  { href: "/sistemas", label: "Sistemas" },
  { href: "/servicios", label: "Servicios" },
  { href: "/contacto", label: "Contacto" },
];

const isActive = (href: string) =>
  href === "/"
    ? pathname === "/"
    : pathname === href || pathname === `${href}/`;
---

<header class="topbar">
  <div class="container topbar__inner">
    <div class="topbar__data">
      <span class="topbar__item topbar__item--address">
        <svg class="topbar__icon" viewBox="0 0 24 24" aria-hidden="true">
          <path
            d="M12 21s-6.5-5.8-6.5-11a6.5 6.5 0 1 1 13 0c0 5.2-6.5 11-6.5 11z"
          ></path>
          <circle cx="12" cy="10" r="2.5"></circle>
        </svg>
        <span>{company.address}</span>
      </span>
      <a href={`mailto:${formRecipients.cc}`} class="topbar__item">
        <svg class="topbar__icon" viewBox="0 0 24 24" aria-hidden="true">
          <rect x="3.2" y="5.2" width="17.6" height="13.6" rx="2"></rect>
          <path d="M4 7l8 6 8-6"></path>
        </svg>
        <span>{formRecipients.cc}</span>
      </a>
      <a href={`tel:${company.phone}`} class="topbar__item">
        <svg class="topbar__icon" viewBox="0 0 24 24" aria-hidden="true">
          <path
            d="M5.6 3.8h3.2l1.4 4.4-1.8 1.8a14.7 14.7 0 0 0 5.6 5.6l1.8-1.8 4.4 1.4v3.2a1.8 1.8 0 0 1-2 1.8A16.4 16.4 0 0 1 3.8 5.8a1.8 1.8 0 0 1 1.8-2z"
          ></path>
        </svg>
        <span>{company.phone}</span>
      </a>
    </div>
  </div>
</header>

<nav class="nav">
  <div class="container nav__inner">
    <a href="/" class="brand" aria-label="Racker inicio">
      <span class="brand__logo-wrap">
        <img
          src="/images/Logo_Racker.png"
          alt="Racker"
          class="brand__logo"
          width="240"
          height="240"
        />
      </span>
    </a>

    <div class="nav__links nav__links--desktop">
      {
        links.map((link) => (
          <a href={link.href} class={isActive(link.href) ? "is-active" : ""}>
            {link.label}
          </a>
        ))
      }
    </div>

    <a
      href="/contacto#cotizar"
      class="btn btn--primary nav__cta nav__cta--desktop"
      data-quote-trigger
    >
      Cotizar ahora
    </a>

    <details class="mobile-menu">
      <summary class="nav__toggle">
        <span class="nav__toggle-icon" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </span>
        <span>Menú</span>
      </summary>
      <div class="mobile-menu__panel">
        <div class="nav__links nav__links--mobile">
          {
            links.map((link) => (
              <a
                href={link.href}
                class={isActive(link.href) ? "is-active" : ""}
              >
                {link.label}
              </a>
            ))
          }
        </div>
        <a
          href="/contacto#cotizar"
          class="btn btn--primary nav__cta nav__cta--mobile"
          data-quote-trigger
        >
          Cotizar ahora
        </a>
      </div>
    </details>
  </div>
</nav>
