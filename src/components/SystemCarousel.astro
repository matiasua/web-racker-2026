---
type CarouselImage = {
  src: string;
  alt: string;
};

const {
  images = [],
  label = "Galería de imágenes",
  loading = "lazy",
  class: className,
} = Astro.props as {
  images?: CarouselImage[];
  label?: string;
  loading?: "eager" | "lazy";
  class?: string;
};
---

<div class:list={["system-carousel", className]} data-carousel aria-label={label}>
  <div class="system-carousel__viewport">
    <div class="system-carousel__track" data-track>
      {images.map((image) => (
        <figure class="system-carousel__slide">
          <img src={image.src} alt={image.alt} loading={loading} />
        </figure>
      ))}
    </div>
  </div>

  <button
    class="system-carousel__btn system-carousel__btn--prev"
    type="button"
    data-dir="-1"
    aria-label="Imagen anterior"
  >
    ‹
  </button>
  <button
    class="system-carousel__btn system-carousel__btn--next"
    type="button"
    data-dir="1"
    aria-label="Imagen siguiente"
  >
    ›
  </button>

  <div class="system-carousel__dots">
    {images.map((image, dotIndex) => (
      <button
        type="button"
        class={`system-carousel__dot ${dotIndex === 0 ? "is-active" : ""}`}
        data-dot={dotIndex}
        aria-label={`Ir a ${image.alt}`}
      />
    ))}
  </div>
</div>

<style is:global>
  .system-carousel {
    position: relative;
    border-radius: 18px;
    overflow: hidden;
    border: 1px solid rgba(10, 23, 48, 0.08);
    box-shadow: 0 10px 22px rgba(10, 23, 48, 0.08);
    background: #dce5ee;
  }

  .system-carousel__viewport {
    overflow: hidden;
    aspect-ratio: 5 / 4;
  }

  .system-carousel__track {
    display: flex;
    width: 100%;
    height: 100%;
    transition: transform 0.35s ease;
  }

  .system-carousel__slide {
    flex: 0 0 100%;
    margin: 0;
    height: 100%;
  }

  .system-carousel__slide img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  .system-carousel__btn {
    position: absolute;
    top: calc(50% - 19px);
    width: 38px;
    height: 38px;
    border: 1px solid rgba(255, 255, 255, 0.55);
    border-radius: 999px;
    background: rgba(12, 24, 46, 0.45);
    color: #fff;
    font-size: 1.35rem;
    line-height: 1;
    cursor: pointer;
    display: grid;
    place-items: center;
    transition: 0.2s ease;
  }

  .system-carousel__btn:hover {
    background: rgba(12, 24, 46, 0.72);
  }

  .system-carousel__btn--prev {
    left: 0.6rem;
  }

  .system-carousel__btn--next {
    right: 0.6rem;
  }

  .system-carousel__dots {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0.5rem;
    display: flex;
    justify-content: center;
    gap: 0.35rem;
  }

  .system-carousel__dot {
    width: 7px;
    height: 7px;
    border-radius: 999px;
    border: 0;
    background: rgba(255, 255, 255, 0.5);
    cursor: pointer;
    padding: 0;
    transition:
      transform 0.2s ease,
      background 0.2s ease;
  }

  .system-carousel__dot.is-active {
    background: #fff;
    transform: scale(1.2);
  }

  .system-carousel.is-static .system-carousel__btn,
  .system-carousel.is-static .system-carousel__dots {
    display: none;
  }

  @media (max-width: 1024px) {
    .system-carousel__viewport {
      aspect-ratio: 16 / 10;
    }
  }

  @media (max-width: 760px) {
    .system-carousel__btn {
      width: 34px;
      height: 34px;
      top: calc(50% - 17px);
    }
  }
</style>

<script>
  (() => {
    const reduceMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    const carousels = document.querySelectorAll("[data-carousel]");

    carousels.forEach((carousel) => {
      if (!(carousel instanceof HTMLElement)) return;
      if (carousel.dataset.carouselReady === "true") return;
      carousel.dataset.carouselReady = "true";

      const track = carousel.querySelector("[data-track]");
      if (!(track instanceof HTMLElement)) return;

      const slides = Array.from(
        track.querySelectorAll(".system-carousel__slide"),
      );
      const dots = Array.from(carousel.querySelectorAll("[data-dot]"));
      const navButtons = Array.from(carousel.querySelectorAll("[data-dir]"));

      if (slides.length <= 1) {
        carousel.classList.add("is-static");
        return;
      }

      let index = 0;
      let autoTimer = null;

      const render = () => {
        track.style.transform = `translateX(-${index * 100}%)`;
        dots.forEach((dot, dotIndex) => {
          dot.classList.toggle("is-active", dotIndex === index);
        });
      };

      const goTo = (nextIndex) => {
        index = (nextIndex + slides.length) % slides.length;
        render();
      };

      const stopAuto = () => {
        if (autoTimer) {
          window.clearInterval(autoTimer);
          autoTimer = null;
        }
      };

      const startAuto = () => {
        if (reduceMotion) return;
        stopAuto();
        autoTimer = window.setInterval(() => {
          goTo(index + 1);
        }, 3000);
      };

      navButtons.forEach((button) => {
        button.addEventListener("click", () => {
          const direction = Number(button.getAttribute("data-dir")) || 0;
          goTo(index + direction);
        });
      });

      dots.forEach((dot, dotIndex) => {
        dot.addEventListener("click", () => {
          goTo(dotIndex);
        });
      });

      carousel.addEventListener("mouseenter", stopAuto);
      carousel.addEventListener("mouseleave", startAuto);
      carousel.addEventListener("focusin", stopAuto);
      carousel.addEventListener("focusout", startAuto);

      document.addEventListener("visibilitychange", () => {
        if (document.hidden) {
          stopAuto();
        } else {
          startAuto();
        }
      });

      render();
      startAuto();
    });
  })();
</script>
