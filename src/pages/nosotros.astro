---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout
  title="Nosotros | Racker"
  description="Conoce al equipo de Racker y nuestro enfoque técnico para proyectos de almacenaje industrial seguros, escalables y eficientes."
>
  <Header />
  <section class="page-hero page-hero--small">
    <div class="container">
      <span class="eyebrow">Nosotros</span>
      <h1>Experiencia técnica para proyectos de almacenaje industrial</h1>
      <p>Diseñamos soluciones enfocadas en capacidad, seguridad, circulación y crecimiento operacional.</p>
    </div>
  </section>

  <section class="section about-difference-section">
    <div class="container about-difference">
      <div class="about-difference__intro">
        <span class="eyebrow">Diferencial Racker</span>
        <h2>Qué hace diferente a Racker</h2>
        <span class="about-difference__accent" aria-hidden="true"></span>
        <p class="lead">Trabajamos con una mirada de ingeniería y operación. No se trata sólo de vender racks, sino de proyectar una bodega funcional, segura y rentable.</p>
      </div>
      <div class="about-difference__panel">
        <header class="about-difference__panel-header">
          <span class="eyebrow">Nuestra forma de trabajar</span>
          <span class="about-difference__accent" aria-hidden="true"></span>
        </header>
        <div class="about-difference__list">
          <article class="about-difference__item">
            <span class="about-difference__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24">
                <path d="M4 18V7.5A2.5 2.5 0 0 1 6.5 5H11" />
                <path d="M13 19H6.5A2.5 2.5 0 0 1 4 16.5" />
                <path d="M14 5h6v6" />
                <path d="m20 5-8 8" />
                <path d="M8 13h4v4H8z" />
              </svg>
            </span>
            <div>
              <h3>Enfoque técnico y comercial alineado</h3>
              <p>Unimos criterio de ingeniería con una mirada práctica del negocio.</p>
            </div>
          </article>

          <article class="about-difference__item">
            <span class="about-difference__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24">
                <path d="M4 17h16" />
                <path d="M5 13h4v4H5z" />
                <path d="M10 9h4v8h-4z" />
                <path d="M15 6h4v11h-4z" />
                <path d="M5 7c3.5 0 4.5 3 7 3s3.5-3 7-3" />
              </svg>
            </span>
            <div>
              <h3>Diseños adaptados a flujo real de carga</h3>
              <p>Proyectamos soluciones pensadas para la operación diaria de cada bodega.</p>
            </div>
          </article>

          <article class="about-difference__item">
            <span class="about-difference__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24">
                <path d="M5 19V8l7-4 7 4v11" />
                <path d="M8 19v-7h8v7" />
                <path d="M8 12h8" />
                <path d="M10 8h4" />
                <path d="M4 19h16" />
              </svg>
            </span>
            <div>
              <h3>Equipos pensados para uso industrial intensivo</h3>
              <p>Estructuras preparadas para exigencias reales de almacenamiento y movimiento.</p>
            </div>
          </article>

          <article class="about-difference__item">
            <span class="about-difference__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24">
                <path d="M6 19h12" />
                <path d="M8 16h8" />
                <path d="M12 5v11" />
                <path d="m8 9 4-4 4 4" />
                <path d="M5 12a7 7 0 0 0 14 0" />
              </svg>
            </span>
            <div>
              <h3>Acompañamiento antes, durante y después del montaje</h3>
              <p>Apoyamos el proceso completo, desde el levantamiento hasta la puesta en marcha.</p>
            </div>
          </article>
        </div>
      </div>
    </div>
  </section>

  <section class="section section--alt about-process">
    <div class="container">
      <div class="about-process__header">
        <span class="eyebrow">Metodología</span>
        <h2>Cómo ejecutamos cada proyecto</h2>
      </div>
      <div class="timeline about-process__grid">
        <article class="timeline__item about-process__item">
          <div class="about-process__top">
            <span class="about-process__step">Etapa 1</span>
            <span class="about-process__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none">
                <circle cx="11" cy="11" r="6.5"></circle>
                <path d="M16 16l4 4"></path>
                <path d="M8.5 11h5"></path>
                <path d="M11 8.5v5"></path>
              </svg>
            </span>
          </div>
          <h3>Diagnóstico</h3>
          <p>Levantamiento de medidas, altura útil, tipo de carga, rotación y equipos de maniobra.</p>
        </article>
        <article class="timeline__item about-process__item">
          <div class="about-process__top">
            <span class="about-process__step">Etapa 2</span>
            <span class="about-process__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none">
                <rect x="4" y="5" width="16" height="14" rx="2"></rect>
                <path d="M8 9h8"></path>
                <path d="M8 12h8"></path>
                <path d="M8 15h5"></path>
              </svg>
            </span>
          </div>
          <h3>Propuesta técnica</h3>
          <p>Definición de layout, sistema recomendado, memoria de cálculo y proyección de capacidad.</p>
        </article>
        <article class="timeline__item about-process__item">
          <div class="about-process__top">
            <span class="about-process__step">Etapa 3</span>
            <span class="about-process__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none">
                <path d="M6 20h12"></path>
                <path d="M8 20V9h8v11"></path>
                <path d="M6 9h12"></path>
                <path d="M10 12h4"></path>
                <path d="M10 15h4"></path>
                <path d="M9 5h6l1 4H8l1-4z"></path>
              </svg>
            </span>
          </div>
          <h3>Implementación</h3>
          <p>Fabricación, coordinación de montaje y validación en terreno con foco en seguridad.</p>
        </article>
      </div>
    </div>
  </section>
  <Footer />
</BaseLayout>

<style>
  .about-difference-section {
    background: linear-gradient(180deg, #f5f7fb 0%, #eef3f8 100%);
  }

  .about-difference {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
    gap: 1.35rem;
    align-items: stretch;
  }

  .about-difference__intro,
  .about-difference__panel {
    position: relative;
    overflow: hidden;
    border-radius: 24px;
    border: 1px solid rgba(10, 23, 48, 0.1);
    box-shadow: 0 18px 40px rgba(12, 28, 52, 0.08);
  }

  .about-difference__intro {
    padding: clamp(1.25rem, 3vw, 2.35rem);
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.98), rgba(241, 247, 253, 0.9)),
      radial-gradient(circle at 92% 14%, rgba(255, 138, 29, 0.11), transparent 38%),
      linear-gradient(90deg, rgba(15, 76, 151, 0.05) 1px, transparent 1px),
      linear-gradient(0deg, rgba(15, 76, 151, 0.04) 1px, transparent 1px);
    background-size: auto, auto, 28px 28px, 28px 28px;
  }

  .about-difference__intro::after,
  .about-difference__panel::after {
    content: "";
    position: absolute;
    right: -4.6rem;
    bottom: -4.8rem;
    width: 18rem;
    height: 18rem;
    border: 1px solid rgba(15, 76, 151, 0.08);
    background:
      linear-gradient(30deg, transparent 47%, rgba(255, 138, 29, 0.2) 48%, rgba(255, 138, 29, 0.2) 51%, transparent 52%),
      linear-gradient(90deg, rgba(15, 76, 151, 0.07) 1px, transparent 1px),
      linear-gradient(0deg, rgba(15, 76, 151, 0.06) 1px, transparent 1px);
    background-size: auto, 24px 24px, 24px 24px;
    opacity: 0.5;
    transform: rotate(-8deg);
    pointer-events: none;
  }

  .about-difference__intro h2 {
    position: relative;
    z-index: 1;
    max-width: 12ch;
    margin: 0;
    color: #0d1b2a;
    font-size: clamp(2rem, 4vw, 3.4rem);
    line-height: 1.06;
    letter-spacing: -0.04em;
  }

  .about-difference__accent {
    position: relative;
    z-index: 1;
    display: block;
    width: 56px;
    height: 3px;
    margin: 1rem 0 1.35rem;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--accent), #ff6d00);
  }

  .about-difference__intro .lead {
    position: relative;
    z-index: 1;
    max-width: 46ch;
    margin: 0;
    color: #536176;
    font-size: 1.03rem;
    line-height: 1.75;
  }

  .about-difference__panel {
    padding: clamp(1.15rem, 2.3vw, 2rem);
    background:
      linear-gradient(160deg, rgba(255, 255, 255, 0.99), rgba(248, 251, 255, 0.94)),
      radial-gradient(circle at 100% 42%, rgba(15, 76, 151, 0.07), transparent 42%);
  }

  .about-difference__panel-header,
  .about-difference__list {
    position: relative;
    z-index: 1;
  }

  .about-difference__panel-header .eyebrow {
    margin-bottom: 0;
    color: #0f315f;
  }

  .about-difference__list {
    display: grid;
  }

  .about-difference__item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1rem;
    align-items: center;
    padding: 1rem 0;
    border-top: 1px solid rgba(10, 23, 48, 0.1);
  }

  .about-difference__item:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .about-difference__icon {
    width: 58px;
    height: 58px;
    display: grid;
    place-items: center;
    border-radius: 999px;
    color: var(--accent);
    background:
      linear-gradient(180deg, #ffffff 0%, #eef4fb 100%),
      radial-gradient(circle at 50% 20%, rgba(255, 138, 29, 0.14), transparent 60%);
    border: 1px solid rgba(15, 76, 151, 0.09);
    box-shadow: 0 12px 22px rgba(10, 23, 48, 0.07);
  }

  .about-difference__icon svg {
    width: 31px;
    height: 31px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.6;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .about-difference__item h3 {
    margin: 0 0 0.3rem;
    color: #10213b;
    font-size: clamp(1rem, 1.45vw, 1.22rem);
    line-height: 1.18;
    letter-spacing: -0.015em;
  }

  .about-difference__item p {
    margin: 0;
    color: #5a687d;
    font-size: 0.94rem;
    line-height: 1.45;
  }

  .about-process {
    background: linear-gradient(180deg, #edf3fb 0%, #e8eef8 100%);
    padding: 3.4rem 0;
  }

  .about-process__header {
    margin-bottom: 1rem;
    max-width: 620px;
  }

  .about-process__header h2 {
    margin: 0;
    letter-spacing: -0.02em;
    font-size: clamp(1.6rem, 3.2vw, 2.2rem);
    line-height: 1.08;
  }

  .about-process__grid {
    gap: 0.8rem;
  }

  .about-process__item {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    border-radius: 24px;
    border: 1px solid rgba(13, 27, 42, 0.08);
    background:
      linear-gradient(180deg, #ffffff 0%, #f8faff 100%),
      radial-gradient(circle at 94% 8%, rgba(15, 76, 151, 0.07), transparent 44%);
    padding: 1rem 0.9rem 0.9rem 1rem;
    min-height: 0;
    box-shadow: 0 14px 28px rgba(10, 23, 48, 0.08);
    overflow: hidden;
  }

  .about-process__item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 6px;
    background: linear-gradient(180deg, var(--accent), #ff6d00);
  }

  .about-process__top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.52rem;
  }

  .about-process__step {
    display: inline-flex;
    align-items: center;
    min-height: 24px;
    border-radius: 999px;
    border: 1px solid rgba(255, 138, 29, 0.25);
    background: rgba(255, 138, 29, 0.14);
    color: #c55e00;
    font-size: 0.64rem;
    font-weight: 800;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 0 0.5rem;
  }

  .about-process__icon {
    width: 34px;
    height: 34px;
    border-radius: 10px;
    display: grid;
    place-items: center;
    background: rgba(15, 76, 151, 0.08);
    border: 1px solid rgba(15, 76, 151, 0.2);
    color: var(--primary);
  }

  .about-process__icon svg {
    width: 18px;
    height: 18px;
    stroke: currentColor;
    stroke-width: 1.9;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .about-process__item h3 {
    margin: 0 0 0.45rem;
    color: var(--primary);
    font-size: clamp(1.38rem, 2vw, 1.82rem);
    letter-spacing: -0.02em;
    line-height: 1.06;
  }

  .about-process__item p {
    margin: 0;
    color: #526077;
    font-size: clamp(0.94rem, 1.12vw, 1.02rem);
    line-height: 1.45;
    max-width: 32ch;
  }

  @media (max-width: 1024px) {
    .about-difference {
      grid-template-columns: 1fr;
    }

    .about-process {
      padding: 3rem 0;
    }

    .about-process__item {
      padding: 0.95rem 0.86rem 0.86rem 0.95rem;
      border-radius: 20px;
    }

    .about-process__icon {
      width: 32px;
      height: 32px;
      border-radius: 9px;
    }
  }

  @media (max-width: 760px) {
    .about-difference {
      gap: 0.9rem;
    }

    .about-difference__intro,
    .about-difference__panel {
      border-radius: 20px;
      padding: 1.05rem;
    }

    .about-difference__intro::after,
    .about-difference__panel::after {
      width: 12rem;
      height: 12rem;
      right: -5rem;
      bottom: -4rem;
      opacity: 0.34;
    }

    .about-difference__intro h2 {
      max-width: 13ch;
      font-size: clamp(1.9rem, 9vw, 2.55rem);
    }

    .about-difference__intro .lead {
      font-size: 0.96rem;
      line-height: 1.55;
    }

    .about-difference__accent {
      margin: 0.9rem 0 1.05rem;
    }

    .about-difference__item {
      gap: 0.75rem;
      align-items: start;
      padding: 0.86rem 0;
    }

    .about-difference__icon {
      width: 46px;
      height: 46px;
    }

    .about-difference__icon svg {
      width: 25px;
      height: 25px;
    }

    .about-difference__item h3 {
      font-size: 1rem;
    }

    .about-difference__item p {
      font-size: 0.88rem;
    }

    .about-process {
      padding: 2.6rem 0;
    }

    .about-process__header {
      margin-bottom: 0.8rem;
    }

    .about-process__item {
      min-height: 0;
      padding: 0.9rem 0.82rem 0.82rem 0.9rem;
      border-radius: 18px;
    }

    .about-process__item::before {
      width: 5px;
    }

    .about-process__top {
      margin-bottom: 0.45rem;
    }

    .about-process__step {
      min-height: 22px;
      font-size: 0.6rem;
      padding-inline: 0.46rem;
    }

    .about-process__icon {
      width: 30px;
      height: 30px;
      border-radius: 8px;
    }

    .about-process__icon svg {
      width: 16px;
      height: 16px;
      stroke-width: 1.9;
    }

    .about-process__item h3 {
      margin-bottom: 0.38rem;
      font-size: clamp(1.32rem, 7vw, 1.7rem);
    }

    .about-process__item p {
      font-size: 0.92rem;
      line-height: 1.45;
      max-width: none;
    }
  }
</style>
