---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { company } from '../data';

const title = 'Normativas para racks y sistemas de almacenaje en Chile | Racker';
const description = 'Conoce la importancia de las normativas y criterios técnicos para racks industriales, sistemas de almacenaje y estructuras metálicas en bodegas en Chile.';
const pageImage = '/images/servicios/rack_selectivo_3.jpg';

const technicalReferences = [
  {
    title: 'NCh3703:2023',
    text: 'Norma chilena asociada a requisitos de diseño para sistemas de almacenamiento en acero. Es una referencia clave para proyectos de racks y estructuras de almacenaje.',
  },
  {
    title: 'NCh2369',
    text: 'Normativa asociada al diseño sísmico de estructuras e instalaciones industriales. Se debe revisar siempre la versión vigente aplicable al proyecto.',
  },
  {
    title: 'NCh427/2',
    text: 'Referencia técnica relacionada con elementos estructurales de acero conformados en frío, relevante para componentes utilizados en sistemas metálicos.',
  },
  {
    title: 'Buenas prácticas de diseño, montaje e inspección',
    text: 'Además de las normas, un proyecto debe considerar criterios de instalación, revisión, mantenimiento, operación segura y uso adecuado del sistema.',
  },
];

const projectSteps = [
  'Levantamiento técnico de la bodega.',
  'Revisión de operación, flujo y tipo de carga.',
  'Definición del sistema de almacenaje adecuado.',
  'Consideraciones estructurales y de montaje.',
  'Acompañamiento técnico para cotización, fabricación e instalación.',
];

const checklist = [
  'Tipo y peso de la carga.',
  'Altura disponible.',
  'Condición del piso.',
  'Tipo de pallet o unidad de carga.',
  'Flujo de grúas y equipos de movimiento.',
  'Separaciones, pasillos y zonas de circulación.',
  'Condiciones de montaje.',
  'Necesidad de inspección y mantenimiento.',
  'Requisitos técnicos aplicables según el proyecto.',
];

const relatedLinks = [
  { href: '/sistemas/rack-selectivo/', title: 'Rack Selectivo', text: 'Acceso directo a cada pallet para operaciones con alta variedad de SKU.' },
  { href: '/sistemas/rack-drive-in/', title: 'Rack Drive In', text: 'Almacenamiento de alta densidad para productos homogéneos o grandes volúmenes.' },
  { href: '/sistemas/altillo-rack/', title: 'Altillo Rack', text: 'Solución para aumentar superficie útil aprovechando la altura disponible.' },
  { href: '/sistemas/altillo-industrial/', title: 'Altillo Industrial', text: 'Estructuras metálicas para ampliar superficie operativa en bodegas e industria.' },
  { href: '/servicios/', title: 'Servicios', text: 'Diseño, fabricación, montaje y acompañamiento técnico para proyectos industriales.' },
  { href: '/contacto#cotizar', title: 'Cotizar proyecto', text: 'Comparte los datos de tu bodega y operación para evaluar una solución.' },
];

const faqItems = [
  {
    question: '¿Por qué es importante considerar normativa en un proyecto de racks?',
    answer: 'Porque los sistemas de almacenaje trabajan con cargas, alturas, equipos de movimiento y condiciones de uso que deben evaluarse técnicamente. Las normas y criterios aplicables ayudan a orientar decisiones de diseño, montaje, uso e inspección según cada proyecto.',
  },
  {
    question: '¿Todos los sistemas de almacenaje requieren el mismo análisis técnico?',
    answer: 'No. Un rack selectivo, un rack drive in o un altillo pueden tener exigencias distintas según carga, altura, operación, recinto y forma de uso. Cada solución debe revisarse con sus condiciones reales antes de definir una propuesta.',
  },
  {
    question: '¿Qué información se necesita para cotizar un sistema de racks?',
    answer: 'Normalmente se requiere información de dimensiones de la bodega, tipo de carga, peso, medidas de pallet, altura disponible, equipos de movimiento, flujo operativo y objetivos de capacidad. Con esos antecedentes se puede orientar mejor la solución.',
  },
  {
    question: '¿Qué se debe revisar antes del montaje de un sistema de almacenaje?',
    answer: 'Se deben revisar condiciones del recinto, piso, accesos, interferencias, zonas de circulación, disponibilidad para montaje, cargas proyectadas y criterios técnicos aplicables. La revisión previa permite reducir ajustes en terreno y mejorar la puesta en marcha.',
  },
  {
    question: '¿Racker puede asesorar en la elección del sistema adecuado?',
    answer: 'Sí. Racker puede apoyar la evaluación comercial y técnica inicial para orientar la selección del sistema de almacenaje más adecuado según la operación, la carga y las condiciones de la bodega. La definición final debe considerar los antecedentes específicos del proyecto.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<BaseLayout
  title={title}
  description={description}
  image={pageImage}
  schema={[faqSchema]}
>
  <Header />

  <section class="normativas-hero">
    <div class="container normativas-hero__grid">
      <div class="normativas-hero__copy">
        <span class="eyebrow">Normativas y seguridad</span>
        <h1>Normativas para racks y sistemas de almacenaje en Chile</h1>
        <p>
          En un país sísmico como Chile, los proyectos de almacenaje industrial requieren criterios técnicos que consideren seguridad, operación, cargas, montaje y comportamiento estructural.
        </p>
        <div class="normativas-hero__actions">
          <a href="/contacto#cotizar" class="btn btn--primary" data-quote-trigger>
            Solicitar asesoría técnica
          </a>
          <a href="/sistemas/" class="btn normativas-btn--navy">
            Ver sistemas de almacenaje
          </a>
        </div>
      </div>

      <aside class="normativas-hero__panel" aria-label="Criterios técnicos del proyecto">
        <span>Evaluación técnica</span>
        <strong>Carga, altura, operación, montaje y condiciones reales del recinto.</strong>
        <p>La solución adecuada depende de antecedentes específicos y de los criterios aplicables a cada proyecto.</p>
      </aside>
    </div>
  </section>

  <section class="section normativas-intro">
    <div class="container normativas-two-col">
      <div>
        <span class="eyebrow">Contexto técnico</span>
        <h2>Por qué las normativas son relevantes</h2>
      </div>
      <div class="normativas-rich-text">
        <p>
          Chile es un país de alta actividad sísmica. Por eso, un sistema de almacenaje no debería evaluarse solo por la cantidad de posiciones disponibles, sino también por su relación con la seguridad, la operación diaria y la continuidad de la bodega.
        </p>
        <p>
          Una solución de racks puede depender de variables como carga, altura, tipo de operación, tipo de pallet, ubicación, montaje y condiciones del recinto. Las normas y documentos técnicos ayudan a orientar el análisis, la fabricación, la instalación y la revisión posterior del sistema.
        </p>
        <p class="normativas-note">
          La información de esta página es referencial. La aplicación normativa y los criterios de diseño deben evaluarse según las condiciones específicas de cada proyecto.
        </p>
      </div>
    </div>
  </section>

  <section class="section section--alt normativas-section">
    <div class="container">
      <div class="section-heading normativas-heading">
        <div>
          <span class="eyebrow">Referencias</span>
          <h2>Normas y documentos técnicos relacionados</h2>
        </div>
        <p>Estas referencias pueden aplicar según el tipo de proyecto, sus cargas, ubicación, componentes y condiciones de uso.</p>
      </div>

      <div class="normativas-card-grid">
        {technicalReferences.map((item) => (
          <article class="normativas-card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section normativas-section">
    <div class="container normativas-process">
      <div class="normativas-process__intro">
        <span class="eyebrow">Metodología</span>
        <h2>Qué considera Racker en un proyecto</h2>
        <p>
          En Racker abordamos cada proyecto desde una mirada técnica y operacional, buscando que la solución propuesta responda tanto a la capacidad requerida como a las condiciones reales de uso.
        </p>
      </div>

      <div class="normativas-steps">
        {projectSteps.map((step, index) => (
          <article class="normativas-step">
            <span>{String(index + 1).padStart(2, '0')}</span>
            <p>{step}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--alt normativas-section">
    <div class="container normativas-check-section">
      <div>
        <span class="eyebrow">Antes de instalar</span>
        <h2>Aspectos que deben revisarse antes de instalar racks</h2>
      </div>
      <ul class="normativas-checklist">
        {checklist.map((item) => <li>{item}</li>)}
      </ul>
    </div>
  </section>

  <section class="section normativas-section">
    <div class="container">
      <div class="section-heading normativas-heading">
        <div>
          <span class="eyebrow">Enlaces internos</span>
          <h2>Sistemas relacionados</h2>
        </div>
      </div>

      <div class="normativas-link-grid">
        {relatedLinks.map((item) => (
          <a class="normativas-link-card" href={item.href}>
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--alt normativas-section">
    <div class="container normativas-faq">
      <div class="normativas-faq__intro">
        <span class="eyebrow">Preguntas frecuentes</span>
        <h2>FAQ sobre racks, normativa y criterios técnicos</h2>
      </div>

      <div class="normativas-faq__list">
        {faqItems.map((item) => (
          <details class="normativas-faq__item">
            <summary>
              <h3>{item.question}</h3>
            </summary>
            <div class="normativas-faq__answer">
              <p>{item.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="section normativas-final-section">
    <div class="container">
      <div class="normativas-final-cta">
        <div>
          <span class="eyebrow">Asesoría técnica</span>
          <h2>¿Necesitas evaluar un proyecto de almacenaje?</h2>
          <p>
            Cuéntanos las características de tu bodega, operación y carga. Podemos ayudarte a definir una solución de almacenaje adecuada para tu proyecto.
          </p>
        </div>
        <div class="normativas-final-cta__actions">
          <a href="/contacto#cotizar" class="btn btn--primary" data-quote-trigger>Solicitar cotización</a>
          <a href={company.whatsapp} class="btn normativas-btn--light" target="_blank" rel="noopener noreferrer">Hablar por WhatsApp</a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<style>
  .normativas-hero {
    position: relative;
    overflow: hidden;
    padding: clamp(4rem, 8vw, 6.5rem) 0;
    background:
      linear-gradient(120deg, rgba(7, 18, 36, 0.9), rgba(10, 36, 72, 0.78)),
      linear-gradient(135deg, rgba(255, 138, 29, 0.18), rgba(15, 76, 151, 0.22)),
      url('/images/servicios/rack_selectivo_3.jpg') center/cover;
    color: #fff;
  }

  .normativas-hero__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(280px, 0.75fr);
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: center;
  }

  .normativas-hero__copy h1 {
    max-width: 820px;
    margin: 0 0 1rem;
    font-size: clamp(2.25rem, 5.5vw, 4.8rem);
    line-height: 0.98;
    letter-spacing: -0.045em;
  }

  .normativas-hero__copy p {
    max-width: 700px;
    margin: 0;
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.75;
    font-size: 1.08rem;
  }

  .normativas-hero__actions,
  .normativas-final-cta__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.7rem;
  }

  .normativas-btn--navy {
    background: #ffffff;
    color: #123e74;
    border-color: rgba(255, 255, 255, 0.9);
    box-shadow: 0 12px 26px rgba(8, 21, 42, 0.24);
  }

  .normativas-btn--light {
    background: #ffffff;
    color: #123e74;
    border-color: #ffffff;
    box-shadow: 0 12px 26px rgba(0, 0, 0, 0.18);
  }

  .normativas-hero__panel {
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(10px);
    box-shadow: 0 22px 46px rgba(0, 0, 0, 0.25);
    padding: clamp(1.2rem, 2.5vw, 1.8rem);
  }

  .normativas-hero__panel span {
    display: inline-block;
    color: #ffb46d;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.78rem;
    margin-bottom: 0.8rem;
  }

  .normativas-hero__panel strong {
    display: block;
    font-size: clamp(1.25rem, 2.4vw, 1.75rem);
    line-height: 1.18;
    letter-spacing: -0.02em;
  }

  .normativas-hero__panel p {
    margin: 0.85rem 0 0;
    color: rgba(255, 255, 255, 0.78);
    line-height: 1.65;
  }

  .normativas-two-col,
  .normativas-check-section,
  .normativas-process {
    display: grid;
    grid-template-columns: 0.75fr 1.25fr;
    gap: clamp(1.5rem, 4vw, 2.5rem);
    align-items: start;
  }

  .normativas-section h2,
  .normativas-intro h2,
  .normativas-final-cta h2 {
    color: #132443;
  }

  .normativas-rich-text p,
  .normativas-process__intro p,
  .normativas-card p,
  .normativas-link-card p,
  .normativas-faq__answer p,
  .normativas-final-cta p,
  .normativas-heading p {
    color: var(--muted);
    line-height: 1.72;
  }

  .normativas-rich-text p:first-child {
    margin-top: 0;
  }

  .normativas-note {
    border-left: 4px solid var(--accent);
    border-radius: 0 16px 16px 0;
    background: #fff7ef;
    padding: 1rem 1.1rem;
    color: #344258 !important;
  }

  .normativas-heading {
    align-items: start;
  }

  .normativas-heading p {
    max-width: 520px;
    margin: 0;
  }

  .normativas-card-grid,
  .normativas-link-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .normativas-link-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .normativas-card,
  .normativas-link-card,
  .normativas-step,
  .normativas-faq__item {
    border: 1px solid rgba(10, 23, 48, 0.1);
    border-radius: 22px;
    background: #fff;
    box-shadow: 0 14px 30px rgba(10, 23, 48, 0.08);
  }

  .normativas-card,
  .normativas-link-card,
  .normativas-faq__item {
    padding: 0;
  }

  .normativas-card,
  .normativas-link-card {
    padding: 1.25rem;
  }

  .normativas-card h3,
  .normativas-link-card h3,
  .normativas-faq__item h3 {
    margin: 0;
    color: #174f97;
    font-size: 1.12rem;
  }

  .normativas-card h3,
  .normativas-link-card h3 {
    margin-bottom: 0.55rem;
  }

  .normativas-card p,
  .normativas-link-card p,
  .normativas-faq__answer p {
    margin: 0;
  }

  .normativas-faq__item {
    overflow: hidden;
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease,
      background 0.2s ease;
  }

  .normativas-faq__item[open] {
    border-color: rgba(255, 138, 29, 0.38);
    background: linear-gradient(180deg, #ffffff 0%, #fffaf5 100%);
    box-shadow: 0 16px 34px rgba(10, 23, 48, 0.1);
  }

  .normativas-faq__item summary {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1rem;
    align-items: center;
    min-height: 64px;
    padding: 1rem 1.15rem;
    cursor: pointer;
    list-style: none;
    color: #174f97;
    -webkit-tap-highlight-color: transparent;
  }

  .normativas-faq__item summary::marker {
    display: none;
    content: '';
  }

  .normativas-faq__item summary::-webkit-details-marker {
    display: none;
  }

  .normativas-faq__item summary:focus-visible {
    outline: 3px solid rgba(255, 138, 29, 0.28);
    outline-offset: -4px;
  }

  .normativas-faq__item summary::after {
    content: '+';
    display: grid;
    place-items: center;
    width: 32px;
    height: 32px;
    flex: 0 0 auto;
    border-radius: 999px;
    border: 1px solid rgba(255, 138, 29, 0.58);
    background: #fff8f0;
    color: var(--accent);
    font-weight: 900;
    line-height: 1;
    font-size: 1.12rem;
    transition:
      background 0.2s ease,
      border-color 0.2s ease,
      color 0.2s ease,
      transform 0.2s ease;
  }

  .normativas-faq__item[open] summary::after {
    content: '–';
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
    transform: scale(1.02);
  }

  .normativas-faq__answer {
    margin: 0 1.15rem 1.15rem;
    padding-top: 0.9rem;
    border-top: 1px solid rgba(10, 23, 48, 0.08);
    animation: normativas-faq-open 0.22s ease;
  }

  @keyframes normativas-faq-open {
    from {
      opacity: 0;
      transform: translateY(-4px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .normativas-link-card {
    display: block;
    text-decoration: none;
    transition:
      transform 0.2s ease,
      border-color 0.2s ease;
  }

  .normativas-link-card:hover {
    transform: translateY(-3px);
    border-color: rgba(255, 138, 29, 0.45);
  }

  .normativas-steps,
  .normativas-faq__list {
    display: grid;
    gap: 0.9rem;
  }

  .normativas-step {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.95rem;
    align-items: center;
    padding: 1rem;
  }

  .normativas-step span {
    display: grid;
    place-items: center;
    width: 42px;
    height: 42px;
    border-radius: 999px;
    background: rgba(255, 138, 29, 0.16);
    color: #d56700;
    font-weight: 800;
  }

  .normativas-step p {
    margin: 0;
    color: #25344d;
    line-height: 1.55;
  }

  .normativas-checklist {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .normativas-checklist li {
    position: relative;
    padding: 0.9rem 1rem 0.9rem 2.35rem;
    border: 1px solid rgba(10, 23, 48, 0.09);
    border-radius: 18px;
    background: #fff;
    color: #25344d;
    line-height: 1.5;
  }

  .normativas-checklist li::before {
    content: '';
    position: absolute;
    left: 1rem;
    top: 1.15rem;
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 999px;
    background: var(--primary);
    box-shadow: 0 0 0 4px rgba(15, 76, 151, 0.1);
  }

  .normativas-faq {
    display: grid;
    grid-template-columns: 0.75fr 1.25fr;
    gap: clamp(1.5rem, 4vw, 2.5rem);
  }

  .normativas-final-section {
    padding-top: 0;
  }

  .normativas-final-cta {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 1.4rem;
    align-items: center;
    border-radius: 28px;
    background:
      radial-gradient(circle at 84% 20%, rgba(255, 138, 29, 0.18), transparent 42%),
      linear-gradient(120deg, #0a1730, #0f264b);
    color: #fff;
    padding: clamp(1.35rem, 3vw, 2.1rem);
    box-shadow: 0 18px 42px rgba(10, 23, 48, 0.16);
  }

  .normativas-final-cta h2 {
    color: #fff;
  }

  .normativas-final-cta p {
    max-width: 650px;
    color: rgba(255, 255, 255, 0.82);
  }

  .normativas-final-cta__actions {
    justify-content: flex-end;
    margin-top: 0;
  }

  @media (max-width: 1024px) {
    .normativas-hero__grid,
    .normativas-two-col,
    .normativas-check-section,
    .normativas-process,
    .normativas-faq,
    .normativas-final-cta {
      grid-template-columns: 1fr;
    }

    .normativas-card-grid,
    .normativas-link-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .normativas-final-cta__actions {
      justify-content: flex-start;
    }
  }

  @media (max-width: 760px) {
    .normativas-hero {
      padding: 3.7rem 0;
    }

    .normativas-hero__actions .btn,
    .normativas-final-cta__actions .btn {
      width: 100%;
    }

    .normativas-card-grid,
    .normativas-link-grid,
    .normativas-checklist {
      grid-template-columns: 1fr;
    }
  }
</style>
