---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import SystemCarousel from "../../components/SystemCarousel.astro";
import { systems } from "../../data";

const systemMedia = {
  "rack-selectivo": [
    "/images/servicios/rack_selectivo_1.jpg",
    "/images/servicios/rack_selectivo_2.jpg",
    "/images/servicios/rack_selectivo_3.jpg",
    "/images/servicios/rack_selectivo_4.jpg",
    "/images/servicios/rack_selectivo_5.jpg",
    "/images/servicios/rack_selectivo_6.jpg",
  ],
  "rack-drive-in": [
    "/images/servicios/drive_in_1.jpg",
    "/images/servicios/drive_in_2.jpg",
    "/images/servicios/drive_in_3.jpg",
    "/images/servicios/drive_in_4.jpg",
    "/images/servicios/drive_in_5.jpg",
    "/images/servicios/drive_in_6.jpg",
  ],
  "altillo-rack": [
    "/images/servicios/ALTILLO_1_new.jpg",
    "/images/servicios/ALTILLO_2_new.jpg",
    "/images/servicios/ALTILLO_3_new.jpg",
    "/images/servicios/ALTILLO_4_new.jpg",
    "/images/servicios/ALTILLO_5_new.png",
    "/images/servicios/ALTILLO_6_new.jpg",
  ],
  "altillo-industrial": [
    "/images/servicios/Altillo_Industrial_1.jpg",
    "/images/servicios/Altillo_Industrial_2.jpg",
    "/images/servicios/Altillo_Industrial_3.jpg",
    "/images/servicios/Altillo_Industrial_4.jpg",
    "/images/servicios/Altillo_Industrial_5.jpg",
    "/images/servicios/Altillo_Industrial_6.jpg",
  ],
} as const;

const systemImageAltText = {
  "rack-selectivo": [
    "Rack selectivo industrial con niveles para almacenamiento de pallets",
    "Rack selectivo para bodega con pasillos de acceso directo a cada pallet",
    "Rack selectivo instalado para operación logística y control de inventario",
    "Sistema de rack selectivo para almacenaje industrial de alta rotación",
    "Rack selectivo metálico para optimizar posiciones de pallet en bodega",
    "Rack selectivo en centro de distribución para acceso rápido a productos",
  ],
  "rack-drive-in": [
    "Rack drive in con calles profundas para almacenamiento de alta densidad",
    "Rack drive in industrial para maximizar capacidad de pallets por SKU",
    "Rack drive in instalado en bodega para reducir pasillos operativos",
    "Sistema drive in para almacenamiento compacto de productos palletizados",
    "Rack drive in metálico para optimización de espacio en bodega industrial",
    "Rack drive in para operaciones logísticas con alta densidad de almacenaje",
  ],
  "altillo-rack": [
    "Altillo rack modular con estructura metálica para ampliar superficie útil",
    "Altillo rack para bodega con nivel superior de almacenamiento y operación",
    "Altillo rack integrado a sistema de almacenaje para aprovechar altura disponible",
    "Detalle de altillo rack con plataforma elevada para flujo operativo",
    "Altillo rack en bodega para picking y almacenamiento liviano",
    "Altillo rack instalado para optimizar superficie en centro de distribución",
  ],
} as const;

const systemsWithMedia = systems.map((system) => ({
  ...system,
  anchorId: `sistema-${system.slug}`,
  detailUrl: `/sistemas/${system.slug}/`,
  images: systemMedia[system.slug as keyof typeof systemMedia] ?? [],
}));
---

<BaseLayout
  title="Sistemas de Almacenaje Industrial | Racker"
  description="Explora los sistemas de almacenaje de Racker: rack selectivo, drive-in, altillo rack y altillo industrial."
>
  <Header />
  <section class="page-hero page-hero--small">
    <div class="container">
      <span class="eyebrow">Sistemas</span>
      <h1>Soluciones de almacenaje para distintas operaciones</h1>
      <p>
        Selecciona la alternativa que mejor se adapta a tu bodega, tipo de
        pallet y rotación logística.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container systems-quick-grid">
      {
        systemsWithMedia.map((system) => (
          <article class="system-quick-card">
            <h3>{system.name}</h3>
            <p>{system.summary}</p>
            <a href={system.detailUrl} class="btn btn--secondary">
              Ver más
            </a>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section section--alt">
    <div class="container systems-detail-list">
      {
        systemsWithMedia.map((system, index) => (
          <article
            id={system.anchorId}
            class={`system-detail ${index % 2 !== 0 ? "system-detail--reverse" : ""}`}
          >
            <SystemCarousel
              class="system-detail__carousel"
              images={system.images.map((image, imageIndex) => ({
                src: image,
                alt: systemImageAltText[system.slug as keyof typeof systemImageAltText]?.[imageIndex]
                  ?? `${system.name} - imagen ${imageIndex + 1} de proyecto de almacenaje industrial`,
              }))}
              label={`Galería de ${system.name}`}
            />

            <div class="system-detail__content">
              <h2>{system.name}</h2>
              <p>{system.hero}</p>
              <p>{system.summary}</p>
              <ul>
                {system.benefits.map((benefit) => (
                  <li>{benefit}</li>
                ))}
              </ul>
              <a
                href={system.detailUrl}
                class="btn btn--primary"
              >
                Más detalle
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </section>
  <Footer />
</BaseLayout>

<style>
  .systems-quick-grid,
  .systems-detail-list {
    position: relative;
    z-index: 2;
  }

  .systems-quick-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
    margin-top: -3.4rem;
  }

  .system-quick-card {
    background:
      linear-gradient(160deg, #ffffff 0%, #f5f9ff 88%),
      radial-gradient(
        circle at 85% 15%,
        rgba(15, 76, 151, 0.07),
        transparent 55%
      );
    border: 1px solid rgba(14, 30, 56, 0.1);
    border-radius: 20px;
    box-shadow: 0 14px 30px rgba(11, 28, 53, 0.08);
    padding: 1.15rem 1.05rem 1rem;
    min-height: 210px;
    display: grid;
    align-content: start;
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
  }

  .system-quick-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 18px 34px rgba(11, 28, 53, 0.14);
  }

  .system-quick-card h3 {
    margin: 0 0 0.45rem;
    font-size: clamp(1.2rem, 2.1vw, 1.5rem);
    color: #132443;
    letter-spacing: -0.015em;
  }

  .system-quick-card p {
    margin: 0 0 0.9rem;
    color: var(--muted);
    line-height: 1.5;
    font-size: 0.98rem;
  }

  .system-quick-card .btn {
    width: fit-content;
    min-height: 38px;
    padding-inline: 1rem;
    border-radius: 999px;
    background: #e7edf5;
    color: #184f98;
    border: 1px solid rgba(15, 76, 151, 0.08);
    font-weight: 700;
  }

  .systems-detail-list {
    display: grid;
    gap: 1.35rem;
  }

  .system-detail {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.55rem;
    align-items: center;
    scroll-margin-top: 132px;
    background: #fff;
    border: 1px solid rgba(10, 23, 48, 0.1);
    border-radius: 24px;
    box-shadow: 0 16px 34px rgba(11, 28, 53, 0.08);
    padding: 1.05rem;
  }

  .system-detail--reverse :global(.system-detail__carousel) {
    order: 2;
  }

  .system-detail--reverse .system-detail__content {
    order: 1;
  }

  .system-detail__content h2 {
    margin: 0 0 0.62rem;
    font-size: clamp(1.55rem, 3vw, 2.3rem);
    letter-spacing: -0.02em;
    color: #132443;
  }

  .system-detail__content p {
    margin: 0 0 0.5rem;
    color: var(--muted);
    line-height: 1.55;
    font-size: 0.98rem;
  }

  .system-detail__content ul {
    margin: 0.4rem 0 0.95rem;
    padding-left: 1.05rem;
  }

  .system-detail__content li {
    margin-bottom: 0.35rem;
    line-height: 1.45;
    color: #1e2f4a;
    font-size: 0.94rem;
  }

  .system-detail__content .btn {
    min-height: 44px;
  }

  @media (max-width: 1024px) {
    .systems-quick-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      margin-top: -2.8rem;
    }

    .system-detail {
      grid-template-columns: 1fr;
      gap: 1.1rem;
      padding: 0.9rem;
    }

    .system-detail--reverse :global(.system-detail__carousel),
    .system-detail--reverse .system-detail__content {
      order: initial;
    }
  }

  @media (max-width: 760px) {
    .systems-quick-grid {
      grid-template-columns: 1fr;
      margin-top: 0;
    }

    .system-quick-card {
      min-height: 0;
      padding: 1rem;
      border-radius: 18px;
    }

    .system-detail {
      padding: 0.75rem;
      border-radius: 20px;
    }

    .system-detail__content h2 {
      font-size: clamp(1.45rem, 8vw, 2.2rem);
    }

  }
</style>
