---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { systems } from '../../data';

const system = systems.find((item) => item.slug === 'protectores-de-marco');
---
<BaseLayout
  title={`${system?.name ?? "Protectores de Marco"} | Racker`}
  description={system?.summary}
>
  <Header />
  <section class="page-hero">
    <div class="container">
      <span class="eyebrow">Sistema de almacenaje</span>
      <h1>{system?.name}</h1>
      <p>{system?.hero}</p>
    </div>
  </section>

  <section class="section">
    <div class="container split">
      <div class="panel panel--media"></div>
      <div>
        <h2>Descripción general</h2>
        <p class="lead">{system?.summary}</p>
        <ul class="check-list">
          {system?.benefits.map((item) => <li>{item}</li>)}
        </ul>
        <a href="/contacto#cotizar" class="btn btn--primary" data-quote-trigger data-quote-product={system?.name}>
          Solicitar cotización
        </a>
      </div>
    </div>
  </section>
  <Footer />
</BaseLayout>
