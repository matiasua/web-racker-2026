---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { company } from '../data';

const servicePillars = [
  {
    kicker: '01',
    title: 'Diseño de proyecto (2D, 3D) y memoria de cálculo',
    description:
      'Levantamos tu operación para definir una solución técnica segura, escalable y ajustada al layout real de tu bodega.',
    points: [
      'Diagnóstico de operación y capacidad',
      'Definición estructural con foco en seguridad',
    ],
  },
  {
    kicker: '02',
    title: 'Fabricación y terminaciones industriales',
    description:
      'Fabricamos estructuras con estándares de resistencia y acabados preparados para operación intensiva en ambientes exigentes.',
    points: [
      'Componentes certificados y control dimensional',
      'Galvanizado y protección para mayor durabilidad',
    ],
  },
  {
    kicker: '03',
    title: 'Montaje, mantenimiento y continuidad operacional',
    description:
      'Ejecutamos instalación en terreno y planes de mantención para mantener tu sistema de almacenaje en óptimo rendimiento.',
    points: [
      'Puesta en marcha con acompañamiento técnico',
      'Revisión preventiva para reducir detenciones',
    ],
  },
];
---
<BaseLayout
  title="Servicios de Almacenaje Industrial | Racker"
  description="Servicios de ingeniería, fabricación, montaje y mantenimiento de sistemas de almacenaje industrial para bodegas y centros de distribución."
>
  <Header />

  <section class="services-hero">
    <div class="container services-hero__content">
      <span class="eyebrow">Servicios</span>
      <h1>Servicios profesionales para optimizar tu almacenaje industrial</h1>
      <p>
        Diseñamos, fabricamos e implementamos soluciones a medida para aumentar
        capacidad, mejorar seguridad y ordenar tu operación logística.
      </p>
      <div class="services-hero__actions">
        <a href="/contacto#cotizar" class="btn btn--primary" data-quote-trigger>
          Solicitar cotización
        </a>
        <a
          href={company.whatsapp}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn--ghost-light services-hero__whatsapp"
        >
          Hablar por WhatsApp
        </a>
      </div>
    </div>
  </section>

  <section class="section services-intro">
    <div class="container">
      <header class="services-intro__header">
        <span class="eyebrow">Cómo trabajamos</span>
        <h2>
          Soluciones integrales y personalizadas para maximizar la eficiencia
          de tu espacio de almacenaje
        </h2>
        <p class="lead">
          En Racker ejecutamos proyectos de punta a punta: ingeniería, fabricación,
          montaje y soporte para que tu operación sea más segura y rentable.
        </p>
      </header>

      <div class="services-pillar-grid">
        {
          servicePillars.map((pillar) => (
            <article class="services-pillar-card">
              <span class="services-pillar-card__kicker">{pillar.kicker}</span>
              <h3>{pillar.title}</h3>
              <p>{pillar.description}</p>
              <ul>
                {pillar.points.map((point) => (
                  <li>{point}</li>
                ))}
              </ul>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--alt services-showcase">
    <div class="container">
      <div class="services-showcase__heading">
        <span class="eyebrow">En terreno</span>
        <h2>Implementación real y foco en seguridad operacional</h2>
      </div>

      <div class="services-showcase__grid">
        <article class="services-image-card">
          <img
            src="/images/servicios/rack_selectivo_3.jpg"
            alt="Sistema de rack selectivo instalado en bodega"
            loading="lazy"
          />
          <div class="services-image-card__caption">
            <h3>Instalación y ordenamiento de bodega</h3>
            <p>
              Proyectos orientados a mejorar flujo, capacidad y control por ubicación.
            </p>
          </div>
        </article>

        <article class="services-image-card services-image-card--poster">
          <img
            src="/images/servicios/Errores-comunes-3-scaled.jpg"
            alt="Campaña visual de seguridad y prevención de pérdidas en bodega"
            loading="lazy"
          />
          <div class="services-image-card__caption">
            <h3>Prevención de errores y accidentes</h3>
            <p>
              Diseñamos soluciones para proteger infraestructura, productos y equipos.
            </p>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="section services-cta">
    <div class="container services-cta__inner">
      <div>
        <span class="eyebrow">Siguiente paso</span>
        <h2>Conversemos la mejor solución para tu operación</h2>
        <p>
          Cuéntanos tu necesidad y te ayudamos a definir una propuesta técnica
          y comercial alineada a tu negocio.
        </p>
      </div>
      <div class="services-cta__actions">
        <a href="/contacto#cotizar" class="btn btn--primary" data-quote-trigger>
          Solicitar cotización
        </a>
        <a
          href={company.whatsapp}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn--secondary"
        >
          Contactar por WhatsApp
        </a>
      </div>
    </div>
  </section>
  <Footer />
</BaseLayout>

<style>
  .services-hero {
    position: relative;
    padding: 6rem 0;
    min-height: min(70vh, 620px);
    display: grid;
    align-items: center;
    background:
      linear-gradient(120deg, rgba(8, 21, 42, 0.78), rgba(8, 21, 42, 0.46)),
      linear-gradient(180deg, rgba(255, 138, 29, 0.14), transparent 60%),
      url('/images/servicios/rack_selectivo_3.jpg') center/cover;
  }

  .services-hero__content {
    max-width: 760px;
    position: relative;
    z-index: 1;
  }

  .services-hero h1 {
    margin: 0 0 1rem;
    font-size: clamp(2.2rem, 5vw, 4.2rem);
    line-height: 0.98;
    letter-spacing: -0.03em;
    color: #fff;
  }

  .services-hero p {
    margin: 0;
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.7;
    font-size: 1.06rem;
    max-width: 62ch;
  }

  .services-hero__actions {
    margin-top: 1.7rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  .services-hero__whatsapp {
    background: #ffffff;
    color: #123e74;
    border-color: rgba(255, 255, 255, 0.92);
    box-shadow: 0 12px 26px rgba(8, 21, 42, 0.24);
  }

  .services-hero__whatsapp:hover {
    background: #f3f7fc;
    border-color: #ffffff;
    color: #0a1730;
    box-shadow: 0 16px 30px rgba(8, 21, 42, 0.3);
  }

  .services-intro {
    margin-top: -2.7rem;
    position: relative;
    z-index: 2;
  }

  .services-intro__header {
    max-width: 980px;
    margin: 0 auto 1.65rem;
    text-align: center;
    background: #fff;
    border: 1px solid rgba(10, 23, 48, 0.08);
    box-shadow: 0 18px 40px rgba(8, 21, 42, 0.08);
    border-radius: 22px;
    padding: 1.8rem 1.4rem;
  }

  .services-intro__header h2 {
    margin: 0 0 0.8rem;
    font-size: clamp(1.75rem, 4vw, 3rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
  }

  .services-intro__header .lead {
    margin: 0;
  }

  .services-pillar-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .services-pillar-card {
    background:
      linear-gradient(180deg, #ffffff 0%, #f7faff 100%),
      radial-gradient(circle at 92% 8%, rgba(15, 76, 151, 0.08), transparent 48%);
    border: 1px solid rgba(10, 23, 48, 0.1);
    border-radius: 20px;
    box-shadow: 0 14px 30px rgba(9, 24, 47, 0.08);
    padding: 1.25rem 1.15rem;
    display: grid;
    align-content: start;
    min-height: 316px;
  }

  .services-pillar-card__kicker {
    width: 34px;
    height: 34px;
    display: inline-grid;
    place-items: center;
    border-radius: 999px;
    background: rgba(255, 138, 29, 0.16);
    color: #d56700;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    margin-bottom: 0.85rem;
  }

  .services-pillar-card h3 {
    margin: 0 0 0.55rem;
    font-size: clamp(1.15rem, 2vw, 1.45rem);
    color: #132443;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .services-pillar-card p {
    margin: 0 0 0.75rem;
    color: var(--muted);
    line-height: 1.58;
    font-size: 0.97rem;
  }

  .services-pillar-card ul {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .services-pillar-card li {
    position: relative;
    padding-left: 1rem;
    color: #23344f;
    line-height: 1.42;
    margin-bottom: 0.42rem;
    font-size: 0.9rem;
  }

  .services-pillar-card li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.54rem;
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 999px;
    background: var(--accent);
  }

  .services-showcase__heading {
    margin-bottom: 1.3rem;
  }

  .services-showcase__heading h2 {
    margin: 0;
    font-size: clamp(1.8rem, 4vw, 2.9rem);
    line-height: 1.06;
    letter-spacing: -0.02em;
    max-width: 18ch;
  }

  .services-showcase__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.15rem;
  }

  .services-image-card {
    background: #fff;
    border: 1px solid rgba(10, 23, 48, 0.1);
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 15px 28px rgba(10, 23, 48, 0.09);
  }

  .services-image-card img {
    width: 100%;
    height: clamp(260px, 36vw, 470px);
    object-fit: cover;
  }

  .services-image-card__caption {
    padding: 1rem 1.05rem 1.1rem;
  }

  .services-image-card__caption h3 {
    margin: 0 0 0.4rem;
    font-size: clamp(1.15rem, 2.2vw, 1.45rem);
    letter-spacing: -0.01em;
    color: #132443;
  }

  .services-image-card__caption p {
    margin: 0;
    line-height: 1.56;
    color: var(--muted);
  }

  .services-image-card--poster img {
    object-position: center 15%;
  }

  .services-cta {
    background:
      radial-gradient(circle at 78% 26%, rgba(255, 138, 29, 0.14), transparent 45%),
      linear-gradient(120deg, #0a1730, #0f264b);
    color: #fff;
  }

  .services-cta__inner {
    display: grid;
    grid-template-columns: 1.35fr 0.65fr;
    align-items: center;
    gap: 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 24px;
    padding: 1.45rem;
    background: rgba(255, 255, 255, 0.02);
    box-shadow: 0 16px 34px rgba(0, 0, 0, 0.24);
  }

  .services-cta__inner h2 {
    margin: 0 0 0.55rem;
    font-size: clamp(1.7rem, 4vw, 2.8rem);
    line-height: 1.03;
    letter-spacing: -0.02em;
  }

  .services-cta__inner p {
    margin: 0;
    color: rgba(255, 255, 255, 0.88);
    line-height: 1.6;
  }

  .services-cta__actions {
    display: grid;
    gap: 0.65rem;
  }

  .services-cta__actions .btn {
    min-height: 47px;
    width: 100%;
  }

  @media (max-width: 1080px) {
    .services-hero {
      padding: 5.2rem 0;
      min-height: min(64vh, 560px);
    }

    .services-pillar-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .services-cta__inner {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 760px) {
    .services-hero {
      min-height: 0;
      padding: 4.3rem 0;
    }

    .services-hero p {
      font-size: 0.98rem;
      line-height: 1.6;
    }

    .services-hero__actions {
      gap: 0.55rem;
    }

    .services-hero__actions .btn {
      width: 100%;
    }

    .services-intro {
      margin-top: -1.8rem;
    }

    .services-intro__header {
      padding: 1.35rem 1rem;
      text-align: left;
      margin-bottom: 1rem;
    }

    .services-pillar-grid {
      grid-template-columns: 1fr;
    }

    .services-pillar-card {
      min-height: 0;
      padding: 1rem;
    }

    .services-showcase__grid {
      grid-template-columns: 1fr;
    }

    .services-image-card img {
      height: clamp(220px, 64vw, 380px);
    }

    .services-cta__inner {
      padding: 1.1rem;
      gap: 1rem;
    }
  }
</style>
